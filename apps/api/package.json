{
  "name": "@briven/api",
  "version": "0.0.0",
  "private": true,
  "description": "api.briven.cloud — control plane",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --hot run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "echo 'lint wired in phase 1'",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@briven/config": "workspace:*",
    "@briven/schema": "workspace:^",
    "@briven/shared": "workspace:*",
    "better-auth": "^1.6.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "maxmind": "^5.0.6",
    "postgres": "^3.4.9",
    "resend": "^6.12.2",
    "standardwebhooks": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
