{
  "name": "@briven/runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Customer function runtime host — deno isolate pool with a Bun/Hono bridge",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "echo 'runtime: no build step — bun runs TS directly'",
    "lint": "echo 'lint wired in phase 1'",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@briven/config": "workspace:*",
    "@briven/schema": "workspace:*",
    "@briven/shared": "workspace:*",
    "hono": "^4.12.16",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
