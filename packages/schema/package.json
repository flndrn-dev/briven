{
  "name": "@briven/schema",
  "version": "0.0.0",
  "private": true,
  "description": "Schema DSL and migration generator for briven projects",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "echo 'lint wired in phase 1'",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/schema.test.ts"
  },
  "dependencies": {
    "@briven/config": "workspace:*",
    "@briven/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
