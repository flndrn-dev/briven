{
  "name": "@briven/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types, zod schemas, error base class, and utilities across the briven monorepo",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./ids": {
      "types": "./src/ids.ts",
      "default": "./src/ids.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "echo 'lint wired in phase 1'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@briven/config": "workspace:*",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
