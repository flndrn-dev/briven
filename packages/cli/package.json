{
  "name": "@briven/cli",
  "version": "0.0.1",
  "description": "ship typescript backends to your own postgres",
  "license": "MIT",
  "type": "module",
  "bin": {
    "briven": "./bin/briven.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo 'lint wired in phase 1'",
    "typecheck": "tsc --noEmit",
    "test": "node --test src/**/*.test.ts"
  },
  "dependencies": {
    "@briven/config": "workspace:*",
    "@briven/schema": "workspace:^",
    "@briven/shared": "workspace:*",
    "chokidar": "^5.0.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "briven",
    "postgres",
    "cli",
    "backend",
    "convex-alternative"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flndrn-dev/briven.git",
    "directory": "packages/cli"
  },
  "homepage": "https://docs.briven.cloud",
  "bugs": "https://github.com/flndrn-dev/briven/issues"
}
